# Copy this file to `.env` and fill in your keys.
# .env is git-ignored — never commit your real keys.

# === Anthropic Claude ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# === 스크랩 기준 (주 1회 토요일 발행) ===
# 조회수 임계값. 2026-07 기준 최근 6주 최고 조회수가 ~5,200회라
# 10000으로 올리면 거의 안 걸림. 3000 = 대략 주 2~3건.
# 잡다한 내용이 많이 섞이면 4000~5000으로 올려볼 것.
VIEW_THRESHOLD=3000
# 목록 스캔 페이지 수 (페이지당 10건, 12페이지 ≈ 최근 6주)
SCAN_PAGES=12
# 1회 실행당 최대 보고 건수 (첫 실행 백로그 폭주 방지)
MAX_ITEMS_PER_RUN=7
# 등록 후 N일 지난 글은 조회수가 기준을 넘어도 제외 ("이번 주" 컨셉 유지)
MAX_AGE_DAYS=14
# 제목 제외 필터 (정규식). 기본: [장관동정]·[차관동정]·[인사] 등 의전성 게시물 제외.
# 비우면 필터 없음.
# EXCLUDE_TITLE_RE=^\[(장관|차관|위원장)?동정\]|^\[인사\]

# === Kakao 나에게 보내기 (kyungje-daily와 같은 카카오 앱 재사용 가능) ===
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://localhost:3000/callback
# (옵션) GitHub Actions 환경에서만 사용 — 로컬에서는 .kakao_tokens.json 우선
# KAKAO_REFRESH_TOKEN=
